@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure authenticator app";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<h3 style="font-size:1.15rem;font-weight:600;margin-bottom:1rem;">@ViewData["Title"]</h3>

<p style="color:var(--text-secondary);font-size:.9rem;">
    To use an authenticator app go through the following steps:
</p>

<ol style="color:var(--text-secondary);font-size:.9rem;padding-left:1.25rem;display:flex;flex-direction:column;gap:1.25rem;">
    <li>
        <p>
            Download a two-factor authenticator app like Microsoft Authenticator for
            <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a> and
            <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a> or
            Google Authenticator for
            <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&hl=en">Android</a> and
            <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
        </p>
    </li>

    <li>
        <p>
            Scan the QR Code or enter this key
            <kbd style="background:var(--bg-subtle);border:1px solid var(--border);border-radius:4px;padding:.2em .5em;font-size:.85em;color:var(--text);">@Model.SharedKey</kbd>
            into your authenticator app.
        </p>
        <div class="alert alert-info d-flex align-items-center gap-2" style="font-size:.85rem;">
            <i class="bi bi-info-circle-fill"></i>
            Learn how to enable QR code generation.
        </div>
        <div id="qrCode" style="margin-top:.5rem;"></div>
        <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
    </li>

    <li>
        <p>
            Once you have scanned the QR code or input the key above, your two factor authentication
            app will provide you with a unique code. Enter the code in the confirmation box below.
        </p>
        <div class="row">
            <div class="col-md-7 col-lg-6">
                <form id="send-code" method="post" style="margin-bottom: 3rem;">
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Code" class="form-control"
                               autocomplete="off" placeholder="Enter 6-digit code" />
                        <label asp-for="Input.Code" class="form-label">Verification Code</label>
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>
                    <button type="submit" class="w-100 btn btn-lg btn-primary">
                        <i class="bi bi-shield-check"></i> Verify
                    </button>
                    <div asp-validation-summary="ModelOnly" class="text-danger mt-2" role="alert"></div>
                </form>
            </div>
        </div>
    </li>
</ol>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    const uri = document.getElementById("qrCodeData").dataset.url;
    new QRCode(document.getElementById("qrCode"), {
        text: uri,
        width: 160,
        height: 160
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
