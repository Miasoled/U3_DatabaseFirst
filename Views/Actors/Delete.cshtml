@model SakilaApp.Models.Actor
@{ ViewData["Title"] = "Eliminar Actor"; }

<div class="page-header">
    <h1><i class="bi bi-trash"></i> Eliminar Actor</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="delete-warning-card mb-4">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                <h3>¿Eliminar este actor?</h3>
                <p>Esta acción no se puede deshacer.</p>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">Actor #@Model?.ActorId</div>
            <div class="card-body p-0">
                <div class="detail-card">
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.FirstName)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.FirstName)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastName)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.LastName)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastUpdate)</span>
                        <span class="detail-value" style="color:var(--text-muted)">@Html.DisplayFor(m => m.LastUpdate)</span>
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="d-flex gap-2">
            <input type="hidden" asp-for="ActorId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Sí, eliminar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>
