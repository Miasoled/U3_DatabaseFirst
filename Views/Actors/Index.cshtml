@model IEnumerable<SakilaApp.Models.Actor>
@{ ViewData["Title"] = "Actores"; }

<div class="page-header">
    <h1><i class="bi bi-person-badge"></i> Actores</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo Actor
    </a>
</div>

<div class="search-bar">
    <form asp-action="Index" method="get">
        <div class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="control-label">Buscar por nombre o apellido</label>
                <input type="text" name="buscar" value="@ViewBag.Buscar"
                       class="form-control" placeholder="Ej: Penelope, Smith..." />
            </div>
            <div class="col-md-6 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">🔍 Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">✕ Limpiar</a>
            </div>
        </div>
    </form>
</div>

<div class="table-wrapper mb-3">
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>@Html.DisplayNameFor(m => m.FirstName)</th>
                <th>@Html.DisplayNameFor(m => m.LastName)</th>
                <th>@Html.DisplayNameFor(m => m.LastUpdate)</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:var(--text-muted);font-size:.8rem;">@item.ActorId</td>
                    <td style="font-weight:600;color:var(--text);">@Html.DisplayFor(i => item.FirstName)</td>
                    <td>@Html.DisplayFor(i => item.LastName)</td>
                    <td style="color:var(--text-muted);font-size:.82rem;">@Html.DisplayFor(i => item.LastUpdate)</td>
                    <td class="text-end table-actions">
                        <a asp-action="Details" asp-route-id="@item.ActorId" class="action-link action-link-view"><i class="bi bi-eye"></i> Ver</a>
                        <a asp-action="Edit"    asp-route-id="@item.ActorId" class="action-link action-link-edit"><i class="bi bi-pencil"></i> Editar</a>
                        <a asp-action="Delete"  asp-route-id="@item.ActorId" class="action-link action-link-delete"><i class="bi bi-trash"></i> Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav aria-label="Paginación">
    <ul class="pagination justify-content-center">
        @if ((int)ViewBag.PaginaActual > 1)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-buscar="@ViewBag.Buscar"
                   asp-route-pagina="@((int)ViewBag.PaginaActual - 1)">
                    ‹ Anterior
                </a>
            </li>
        }
        @for (int i = 1; i <= (int)ViewBag.TotalPaginas; i++)
        {
            <li class="page-item @(i == (int)ViewBag.PaginaActual ? "active" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-buscar="@ViewBag.Buscar"
                   asp-route-pagina="@i">@i</a>
            </li>
        }
        @if ((int)ViewBag.PaginaActual < (int)ViewBag.TotalPaginas)
        {
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-buscar="@ViewBag.Buscar"
                   asp-route-pagina="@((int)ViewBag.PaginaActual + 1)">
                    Siguiente ›
                </a>
            </li>
        }
    </ul>
</nav>
