@model SakilaApp.Models.Actor
@{ ViewData["Title"] = "Detalle del Actor"; }

<div class="page-header">
    <h1><i class="bi bi-person-badge"></i> Detalle del Actor</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Actor #@Model?.ActorId</span>
                <span class="badge" style="background:var(--primary-light);color:var(--primary);font-size:.75rem;padding:.35em .7em;border-radius:20px;font-weight:600;">Actor</span>
            </div>
            <div class="card-body p-0">
                <div class="detail-card">
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.FirstName)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.FirstName)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastName)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.LastName)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastUpdate)</span>
                        <span class="detail-value" style="color:var(--text-muted)">@Html.DisplayFor(m => m.LastUpdate)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit"   asp-route-id="@Model?.ActorId" class="btn btn-primary"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Delete" asp-route-id="@Model?.ActorId" class="btn btn-danger"><i class="bi bi-trash"></i> Eliminar</a>
            <a asp-action="Index" class="btn btn-outline-secondary ms-auto"><i class="bi bi-arrow-left"></i> Listado</a>
        </div>
    </div>
</div>
