@model SakilaApp.Models.Category
@{ ViewData["Title"] = "Detalle de Categoría"; }

<div class="page-header">
    <h1><i class="bi bi-tags"></i> Detalle de Categoría</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card mb-3">
            <div class="card-header">Categoría #@Model?.CategoryId</div>
            <div class="card-body p-0">
                <div class="detail-card">
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Name)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Name)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastUpdate)</span>
                        <span class="detail-value" style="color:var(--text-muted)">@Html.DisplayFor(m => m.LastUpdate)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit"   asp-route-id="@Model?.CategoryId" class="btn btn-primary"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Delete" asp-route-id="@Model?.CategoryId" class="btn btn-danger"><i class="bi bi-trash"></i> Eliminar</a>
            <a asp-action="Index" class="btn btn-outline-secondary ms-auto"><i class="bi bi-arrow-left"></i> Listado</a>
        </div>
    </div>
</div>
