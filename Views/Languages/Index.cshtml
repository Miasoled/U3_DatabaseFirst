@model IEnumerable<SakilaApp.Models.Language>

@{
    ViewData["Title"] = "Idiomas";
}

<div class="page-header">
    <h1><span class="page-header-icon">🌐</span> Idiomas</h1>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo Idioma</a>
</div>

<div class="table-wrapper">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>@Html.DisplayNameFor(m => m.Name)</th>
                <th>@Html.DisplayNameFor(m => m.LastUpdate)</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="text-muted small">@item.LanguageId</span></td>
                    <td><strong style="color:var(--text);">@Html.DisplayFor(i => item.Name)</strong></td>
                    <td><span class="text-muted small">@Html.DisplayFor(i => item.LastUpdate)</span></td>
                    <td class="text-end table-actions">
                        <a asp-action="Details" asp-route-id="@item.LanguageId" class="action-link action-link-details">👁 Ver</a>
                        <a asp-action="Edit"    asp-route-id="@item.LanguageId" class="action-link action-link-edit">✏️ Editar</a>
                        <a asp-action="Delete"  asp-route-id="@item.LanguageId" class="action-link action-link-delete">🗑 Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
