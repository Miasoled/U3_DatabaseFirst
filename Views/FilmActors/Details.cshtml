@model SakilaApp.Models.FilmActor

@{
    ViewData["Title"] = "Detalle Película–Actor";
}

<div class="page-header">
    <h1><span class="page-header-icon">🔗</span> Detalle Película–Actor</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card mb-3">
            <div class="card-header">Relación Película–Actor</div>
            <div class="card-body p-0">
                <div class="detail-card border-0">
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Actor)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Actor.ActorId)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Film)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Film.FilmId)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastUpdate)</span>
                        <span class="detail-value text-muted">@Html.DisplayFor(m => m.LastUpdate)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            @Html.ActionLink("✏️ Editar", "Edit", null, new { @class = "btn btn-primary" })
            <a asp-action="Index" class="btn btn-outline-secondary ms-auto">← Volver al listado</a>
        </div>
    </div>
</div>
