@model SakilaApp.Models.FilmActor

@{
    ViewData["Title"] = "Nueva relación Película–Actor";
}

<div class="page-header">
    <h1><span class="page-header-icon">🔗</span> Nueva relación Película–Actor</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card">
            <div class="card-header">Asignar actor a película</div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="ActorId" class="control-label">Actor</label>
                        <select asp-for="ActorId" class="form-select" asp-items="ViewBag.ActorId"></select>
                    </div>

                    <div class="form-group">
                        <label asp-for="FilmId" class="control-label">Película</label>
                        <select asp-for="FilmId" class="form-select" asp-items="ViewBag.FilmId"></select>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">✓ Guardar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
