@model SakilaApp.Models.Film

@{
    ViewData["Title"] = "Detalle de Película";
}

<div class="page-header">
    <h1><span class="page-header-icon">🎥</span> Detalle de Película</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>@Model?.Title</span>
                <span class="badge badge-primary">@Model?.ReleaseYear</span>
            </div>
            <div class="card-body p-0">
                <div class="detail-card border-0">
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Title)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Title)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Description)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Description)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.ReleaseYear)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.ReleaseYear)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Language)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Language!.Name)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.OriginalLanguage)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.OriginalLanguage!.Name)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.RentalDuration)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.RentalDuration) días</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.RentalRate)</span>
                        <span class="detail-value">$@Html.DisplayFor(m => m.RentalRate)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.Length)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.Length) min</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.ReplacementCost)</span>
                        <span class="detail-value">$@Html.DisplayFor(m => m.ReplacementCost)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.SpecialFeatures)</span>
                        <span class="detail-value">@Html.DisplayFor(m => m.SpecialFeatures)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">@Html.DisplayNameFor(m => m.LastUpdate)</span>
                        <span class="detail-value text-muted">@Html.DisplayFor(m => m.LastUpdate)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.FilmId" class="btn btn-primary">✏️ Editar</a>
            <a asp-action="Delete" asp-route-id="@Model?.FilmId" class="btn btn-danger">🗑 Eliminar</a>
            <a asp-action="Index" class="btn btn-outline-secondary ms-auto">← Volver al listado</a>
        </div>
    </div>
</div>
