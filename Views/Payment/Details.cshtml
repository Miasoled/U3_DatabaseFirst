@model SakilaApp.Models.Commerce.PaymentTransaction

@{
    ViewData["Title"] = "Resumen de pago";
    bool isPaid = Model.Status == "Paid";
    bool isPending = Model.Status == "Pending";
    bool isCanceled = Model.Status == "Canceled";
    decimal total = Model.AmountInCents / 100m;
}

<div class="page-header">
    <h1>
        <i class="bi bi-receipt"></i> Resumen de pago
    </h1>
    <a asp-controller="Store" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-shop"></i> Volver a la tienda
    </a>
</div>

<!-- Estado del pago -->
@if (isPaid)
{
    <div class="alert d-flex align-items-center gap-3 mb-4"
         style="background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;border-radius:10px;padding:1rem 1.25rem;">
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div>
            <strong>Pago confirmado</strong>
            <div style="font-size:.875rem;opacity:.85;">Tu transacción fue procesada correctamente.</div>
        </div>
    </div>
}
else if (isCanceled)
{
    <div class="alert d-flex align-items-center gap-3 mb-4"
         style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;border-radius:10px;padding:1rem 1.25rem;">
        <i class="bi bi-x-circle-fill fs-4"></i>
        <div>
            <strong>Pago cancelado</strong>
            <div style="font-size:.875rem;opacity:.85;">El pago fue cancelado o rechazado.</div>
        </div>
    </div>
}
else if (isPending)
{
    <div class="alert d-flex align-items-center gap-3 mb-4"
         style="background:#fffbeb;border:1px solid #fde68a;color:#d97706;border-radius:10px;padding:1rem 1.25rem;">
        <i class="bi bi-clock-fill fs-4"></i>
        <div>
            <strong>Pago pendiente</strong>
            <div style="font-size:.875rem;opacity:.85;">Completa el pago usando el botón correspondiente.</div>
        </div>
    </div>
}

<div class="row g-4">

    <!-- Columna izquierda: info de transacción -->
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-credit-card" style="color:var(--primary)"></i>
                Información de la transacción
            </div>
            <div class="card-body p-0">
                <div class="detail-card">
                    <div class="detail-row">
                        <span class="detail-label">Orden #</span>
                        <span class="detail-value fw-semibold">@Model.PurchaseOrderId</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Pasarela</span>
                        <span class="detail-value">
                            @if (Model.Provider == "PayPhone")
                            {
                                <span class="badge" style="background:#e0f2fe;color:#0284c7;padding:.35em .75em;border-radius:20px;font-size:.78rem;font-weight:600;">
                                    PayPhone
                                </span>
                            }
                            else if (Model.Provider == "PayPal" || Model.Provider == "PayPalButton")
                            {
                                <span class="badge" style="background:#eff6ff;color:#2563eb;padding:.35em .75em;border-radius:20px;font-size:.78rem;font-weight:600;">
                                    PayPal Sandbox
                                </span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Estado</span>
                        <span class="detail-value">
                            @if (isPaid)
                            {
                                <span style="color:#16a34a;font-weight:600;">
                                    <i class="bi bi-check-circle-fill me-1"></i>Pagado
                                </span>
                            }
                            else if (isCanceled)
                            {
                                <span style="color:#dc2626;font-weight:600;">
                                    <i class="bi bi-x-circle-fill me-1"></i>Cancelado
                                </span>
                            }
                            else
                            {
                                <span style="color:#d97706;font-weight:600;">
                                    <i class="bi bi-clock-fill me-1"></i>Pendiente
                                </span>
                            }
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Total</span>
                        <span class="detail-value fw-bold" style="font-size:1.1rem;color:var(--text);">
                            @total.ToString("C")
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">ID Transacción</span>
                        <span class="detail-value" style="font-size:.8rem;word-break:break-all;color:var(--text-muted);">
                            @Model.ClientTransactionId
                        </span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PayPalCaptureId))
                    {
                        <div class="detail-row">
                            <span class="detail-label">Capture ID</span>
                            <span class="detail-value" style="font-size:.8rem;word-break:break-all;color:var(--text-muted);">
                                @Model.PayPalCaptureId
                            </span>
                        </div>
                    }
                    @if (Model.ConfirmedAt.HasValue)
                    {
                        <div class="detail-row">
                            <span class="detail-label">Confirmado</span>
                            <span class="detail-value" style="color:var(--text-muted);font-size:.85rem;">
                                @Model.ConfirmedAt.Value.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                    }
                </div>
            </div>

            @if (isPending)
            {
                <div class="card-body" style="border-top:1px solid var(--border);padding:1.25rem;">
                    <div class="d-flex flex-column gap-2">
                        @if (Model.Provider == "PayPhone" && !string.IsNullOrWhiteSpace(Model.PayphonePaymentUrl))
                        {
                            <a class="btn btn-primary w-100" href="@Model.PayphonePaymentUrl" target="_blank">
                                <i class="bi bi-phone"></i> Ir a pagar con PayPhone
                            </a>
                        }
                        @if ((Model.Provider == "PayPal") && !string.IsNullOrWhiteSpace(Model.PayPalApprovalUrl))
                        {
                            <a class="btn btn-primary w-100" href="@Model.PayPalApprovalUrl" target="_blank">
                                <i class="bi bi-paypal"></i> Ir a aprobar en PayPal
                            </a>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <a class="btn btn-outline-secondary w-100"
                               asp-action="MarkAsPaid" asp-route-id="@Model.PaymentTransactionId">
                                <i class="bi bi-check2-circle"></i> Marcar como pagado (demo)
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Columna derecha: detalle de la orden -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-bag" style="color:var(--primary)"></i>
                Detalle de la orden
            </div>
            <div class="table-wrapper" style="border:none;border-radius:0;box-shadow:none;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Película</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">Precio</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.PurchaseOrder.Details)
                        {
                            <tr>
                                <td style="font-weight:500;color:var(--text);">@d.FilmTitle</td>
                                <td class="text-center">@d.Quantity</td>
                                <td class="text-end">@d.UnitPrice.ToString("C")</td>
                                <td class="text-end">@d.Subtotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="border-top:2px solid var(--border);">
                            <td colspan="3" class="text-end fw-bold" style="color:var(--text);">Total</td>
                            <td class="text-end fw-bold" style="color:var(--text);font-size:1rem;">
                                @total.ToString("C")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

</div>
