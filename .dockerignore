# ==========================================
# Compilación de .NET (se regeneran en el build del contenedor)
# ==========================================
**/bin/
**/obj/

# ==========================================
# Archivos de editores / IDEs
# ==========================================
.vs/
.vscode/
*.user
*.suo

# ==========================================
# Control de versiones
# ==========================================
.git/
.gitignore

# ==========================================
# Documentación y archivos no necesarios en la imagen
# ==========================================
README.md
ScaffoldingReadMe.txt
screenshots/

# ==========================================
# Archivos de Docker (no deben copiarse dentro de su propia imagen)
# ==========================================
Dockerfile
docker-compose.yml
.dockerignore

# ==========================================
# Secretos y configuración local sensible
# ==========================================
appsettings.Development.json
.env
*.env